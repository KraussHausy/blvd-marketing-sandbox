# Boulevard API
BLVD_API_KEY=your_boulevard_api_key_here
BLVD_BUSINESS_ID=your_business_id_here
BLVD_API_URL=https://dashboard.boulevard.io/api/2020-01

# Webhook listener
WEBHOOK_PORT=3001
WEBHOOK_SECRET=your_webhook_signing_secret

# Klaviyo (optional — only if syncing to Klaviyo)
KLAVIYO_API_KEY=your_klaviyo_private_api_key
KLAVIYO_LIST_ID=your_klaviyo_list_id

# HubSpot (optional — only if syncing to HubSpot)
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token

# Mailchimp (optional — only if syncing to Mailchimp)
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your_mailchimp_audience_id
